{
  "version": 2,
  "builds": [
    {
      "src": "yesorno-server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    { "src": "/generate-answer", "dest": "yesorno-server/server.js" },
    { "src": ".*", "dest": "index.html" } 
  ]
}