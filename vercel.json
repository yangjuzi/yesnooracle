{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/generate-answer", "dest": "server.js" },
    { "src": "/122", "dest": "yes-no-button.html" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/" }] 
}