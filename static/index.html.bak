        <a href="#" class="px-6 py-2 font-normal transition hover:text-[#acacaf]">Support</a>
        <a href="#" class="px-6 py-2 font-normal transition hover:text-[#acacaf]">Help</a>
      </div>
      <div class="mb-4 mt-4 w-48 border-b border-solid border-b-white"></div>
      <p class="text-sm text-white">© Copyright 2024. All rights reserved.</p>
    </div>
  </div>
</footer>
</body>
</html>
