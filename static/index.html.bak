<h1 class="mt-20 mb-8 text-center text-4xl font-extrabold leading-none tracking-tight text-gray-900 md:text-5xl lg:text-6xl dark:text-white">Welcome to visit free simple yes no oracle</h1>

<p class="mb-48 text-lg text-center font-normal text-gray-500 lg:text-xl sm:px-16 xl:px-48 dark:text-gray-400 ">Yes no oracle website is simple free tool that helps you make yes no decisions. Just type your yes no question and click the button oracle.</p>


<div class="w-[50%] mx-auto rounded-tl-[30px] rounded-tr-[30px] border-[12px] border-[#ffffff1f] object-fill"><form class="relative shadow-lg"><div class="overflow-hidden focus-within:ring-1 focus-within:ring-indigo-500 rounded-tl-[20px] rounded-tr-[20px]"><textarea rows="8" name="description" id="description" class="block w-full resize-none border-0 text-gray-900 placeholder:text-gray-400 focus:ring-0 text-lg pt-4 pl-4" placeholder="Type or paste your question here..." maxlength="1000"></textarea></div><div class="inset-x-px bottom-1 bg-white"><div class="flex justify-center items-center space-x-3 border-t border-gray-200 px-2 py-2"><div class="pt-2 w-1/4"><button type="submit" class="w-full inline-flex justify-center items-center rounded-md bg-[#2d6ae0] px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-800">oracle</button></div></div></div></form></div>
<div class="w-[50%] mx-auto rounded-tl-[30px] rounded-tr-[30px] border-[12px] border-[#ffffff1f]">
    <div class="bg-white p-4 shadow-lg">
        <h2 class="text-blue-500 pt-4 text-4xl flex justify-center items-center">YES NO RESULT</h2>
        <div class="overflow-hidden focus-within:ring-1 focus-within:ring-indigo-500 rounded-tl-[20px] rounded-tr-[20px]">
		     <div name="description-display" id="answer-display" class="block w-full resize-none border-0 text-gray-900 placeholder:text-gray-400 focus:ring-0 text-lg pt-4 pl-4 py-40" placeholder="在此处输入或粘贴文本..." maxlength="1000"></div>
            
        </div>
    </div>
</div>
<script>
document.querySelector('button[type="submit"]').addEventListener('click', async (event) => {
    event.preventDefault();

    const description = document.getElementById('description').value;

    const response = await fetch('https://yesnooracle.dev/generate-answer', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ description }),
    });

    if (response.ok) {
      const { answer } = await response.json();
	  

 

      // 清空现有答案内容
      const answerElement = document.getElementById('answer-display');
	  document.getElementById('answer-display').classList.add('height-adjusted');
      answerElement.textContent = '';

      // 根据答案内容添加不同的CSS类
      answerElement.textContent = `question: ${description}`+' is '+ answer;
      answerElement.classList.remove('bg-green-500', 'bg-red-500');
      if (answer.toLowerCase() === 'yes') {
        answerElement.classList.add('bg-green-500');
      } else if (answer.toLowerCase() === 'no') {
        answerElement.classList.add('bg-red-500');
      }
    } else {
      alert('Error generating answer. Please try again.');
    }
});
</script>
<footer class="bg-[#020d24] text-white">
  <div class="mx-auto w-full max-w-7xl px-5 py-8 md:px-10 md:py-12 lg:py-16">
    <div class="flex flex-col items-center">
      <div class="text-center font-semibold max-[991px]:ml-0 max-[991px]:mr-0 max-[991px]:py-1">
