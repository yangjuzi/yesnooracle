  #answer-display {
    font-size: 2rem; /* 更改字体大小，例如 2rem 或者 24px */
  }

  /* 如果您想在不同屏幕尺寸上调整字体大小，可以使用媒体查询 */
  @media (min-width: 768px) {
    #answer-display {
      font-size: 2.5rem; /* 在大屏幕设备上增大字体大小 */
    }
  }
</style>
